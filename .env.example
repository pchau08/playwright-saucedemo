# ─── Application ────────────────────────────────────────────────────────────
BASE_URL=https://www.saucedemo.com

# ─── Test Credentials ────────────────────────────────────────────────────────
# These are the public SauceDemo credentials — safe to commit in .env.example
STANDARD_USER=standard_user
LOCKED_OUT_USER=locked_out_user
PROBLEM_USER=problem_user
PERFORMANCE_GLITCH_USER=performance_glitch_user
ERROR_USER=error_user
VISUAL_USER=visual_user
SAUCE_PASSWORD=secret_sauce

# ─── AI Integration (optional) ───────────────────────────────────────────────
# Set this if you want the AITestHelper to call the OpenAI API.
# If omitted, the helper falls back to static data and tests still pass in CI.
OPENAI_API_KEY=

# ─── Reporting ────────────────────────────────────────────────────────────────
# Optional: post test summary to a Slack webhook after CI runs
SLACK_WEBHOOK_URL=
