{
  "name": "playwright-saucedemo",
  "version": "1.0.0",
  "description": "Production-grade Playwright automation framework for SauceDemo eCommerce — POM, TypeScript, Allure, AI-augmented testing, GitHub Actions CI/CD",
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:auth": "playwright test tests/auth/",
    "test:e2e": "playwright test tests/e2e/",
    "test:catalog": "playwright test tests/catalog/",
    "test:api": "playwright test tests/api/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clean": "rimraf allure-results allure-report",
    "report:show": "playwright show-report",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf allure-results allure-report reports/results.json test-results"
  },
  "dependencies": {
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.4",
    "allure-playwright": "^3.1.3",
    "allure-commandline": "^2.32.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.20.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
